@using System.Globalization
@model PersonalCloud.Models.DocumentViewModel
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["Moje Dokumenty"];
    var culture = CultureInfo.CurrentUICulture.Name;
    var currentFolderId = Model.CurrentFolder?.Id;
    var parentFolderId = Model.CurrentFolder?.ParentFolderId;
}

<div class="d-flex align-items-center justify-content-between mb-2 flex-wrap gap-2">
    <h2 class="mb-0">@ViewData["Title"]</h2>
    <div class="d-flex gap-2 flex-wrap">
        <!-- Upload button -->
        <button type="button" class="btn btn-primary" onclick="document.getElementById('uploadInput').click()">
            <i class="bi bi-cloud-upload me-1"></i> @Localizer["Nahrát"]
        </button>
        <!-- New Folder button -->
        <button type="button" class="btn btn-outline-secondary" onclick="showNewFolderModal()">
            <i class="bi bi-folder-plus me-1"></i> @Localizer["Nová složka"]
        </button>
    </div>
</div>

<!-- Hidden upload form -->
<form id="uploadForm" asp-action="UploadFile" method="post" enctype="multipart/form-data" asp-route-culture="@culture">
    @Html.AntiForgeryToken()
    <input type="hidden" name="folderId" value="@currentFolderId" />
    <input type="file" id="uploadInput" name="file" style="display:none" onchange="this.form.submit()" required />
</form>

@if (TempData["UploadError"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["UploadError"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["UploadSuccess"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["UploadSuccess"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Document", new { culture })" class="text-decoration-none">
                <i class="bi bi-house me-1"></i>@Localizer["Moje Dokumenty"]
            </a>
        </li>
        @foreach (var crumb in Model.Breadcrumb)
        {
            if (crumb.Id == currentFolderId)
            {
                <li class="breadcrumb-item active" aria-current="page">@crumb.Name</li>
            }
            else
            {
                <li class="breadcrumb-item">
                    <a href="@Url.Action("Index", "Document", new { folderId = crumb.Id, culture })" class="text-decoration-none">@crumb.Name</a>
                </li>
            }
        }
    </ol>
</nav>

<!-- Drag-and-drop drop zone onto parent folder (shown when inside a folder) -->
@if (currentFolderId.HasValue)
{
    <div class="mb-3">
        <a href="@Url.Action("Index", "Document", new { folderId = parentFolderId, culture })"
           class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-up me-1"></i>@Localizer["Zpět"]
        </a>
    </div>
}

<!-- Folder Grid -->
@if (Model.SubFolders.Any())
{
    <div class="mb-4">
        <h6 class="text-muted text-uppercase small fw-semibold mb-2">@Localizer["Složky"]</h6>
        <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-5 row-cols-xl-6 g-3" id="folderGrid">
            @foreach (var folder in Model.SubFolders)
            {
                <div class="col">
                    <div class="folder-card card h-100 border-0 shadow-sm"
                         data-folder-id="@folder.Id"
                         ondragover="event.preventDefault(); this.classList.add('drag-over')"
                         ondragleave="this.classList.remove('drag-over')"
                         ondrop="onDropToFolder(event, @folder.Id, this)">
                        <div class="card-body text-center p-3">
                            <a href="@Url.Action("Index", "Document", new { folderId = folder.Id, culture })"
                               class="text-decoration-none folder-link d-block">
                                <i class="bi bi-folder-fill folder-icon text-warning"></i>
                                <div class="folder-name mt-1 text-dark small fw-medium text-truncate" title="@folder.Name">@folder.Name</div>
                            </a>
                        </div>
                        <div class="card-footer bg-transparent border-0 p-1 text-center folder-actions">
                            <button class="btn btn-sm btn-link text-secondary p-0 me-1"
                                    title="@Localizer["Přejmenovat"]"
                                    onclick="showRenameFolderModal(@folder.Id, '@Html.Raw(folder.Name.Replace("'", "\\'"))', @(folder.ParentFolderId?.ToString() ?? "null"))">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <form asp-action="DeleteFolder" method="post" style="display:inline;" asp-route-culture="@culture">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@folder.Id" />
                                <input type="hidden" name="parentFolderId" value="@currentFolderId" />
                                <button type="submit" class="btn btn-sm btn-link text-danger p-0"
                                        title="@Localizer["Smazat složku"]"
                                        onclick="return confirm('@Localizer["Smazat tuto složku? Soubory budou přesunuty do nadřazené složky."]');">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

<!-- Root drop zone (only visible during drag, when inside a subfolder) -->
@if (currentFolderId.HasValue)
{
    <div id="parentDropZone" class="drop-zone-back mb-3 d-none"
         ondragover="event.preventDefault(); this.classList.add('drag-over')"
         ondragleave="this.classList.remove('drag-over')"
         ondrop="onDropToFolder(event, @(parentFolderId?.ToString() ?? "null"), this)">
        <i class="bi bi-arrow-up-circle me-2"></i>@Localizer["Přesunout do nadřazené složky"]
    </div>
}

<!-- Files List -->
<div>
    <h6 class="text-muted text-uppercase small fw-semibold mb-2">@Localizer["Soubory"]</h6>
    @if (Model.DocumentsWithSignature.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle files-table">
                <thead class="table-light">
                <tr>
                    <th>@Localizer["Název"]</th>
                    <th class="d-none d-md-table-cell">@Localizer["Nahráno dne"]</th>
                    <th class="d-none d-sm-table-cell">@Localizer["Velikost (KB)"]</th>
                    <th>@Localizer["Možnosti"]</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.DocumentsWithSignature)
                {
                    <tr class="file-row"
                        draggable="true"
                        data-doc-id="@item.Document.Id"
                        ondragstart="onDragStart(event, @item.Document.Id)"
                        ondragend="onDragEnd(event)">
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-grip-vertical text-muted drag-handle" style="cursor:grab;font-size:1.1rem;"></i>
                                @{
                                    var type = item.Document.ContentType?.ToLower() ?? "";
                                    var iconClass = type == "application/pdf" ? "bi bi-file-earmark-pdf text-danger"
                                        : type.StartsWith("image/") ? "bi bi-file-earmark-image text-info"
                                        : type.StartsWith("audio/") ? "bi bi-vinyl text-primary"
                                        : type == "application/vnd.openxmlformats-officedocument.wordprocessingml.document"
                                          || type == "application/msword" ? "bi bi-file-earmark-word text-primary"
                                        : type == "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
                                          || type == "application/vnd.ms-excel" ? "bi bi-file-earmark-excel text-success"
                                        : type == "application/vnd.openxmlformats-officedocument.presentationml.presentation"
                                          || type == "application/vnd.ms-powerpoint" ? "bi bi-file-earmark-ppt text-warning"
                                        : type.StartsWith("video/") ? "bi bi-file-earmark-play text-danger"
                                        : type.Contains("zip") || type.Contains("compressed") ? "bi bi-file-earmark-zip text-muted"
                                        : type.StartsWith("text/") ? "bi bi-file-earmark-text text-secondary"
                                        : "bi bi-file-earmark text-secondary";

                                    var isPreviewable =
                                        (type.StartsWith("text/", StringComparison.OrdinalIgnoreCase)
                                         && !type.Contains("octet-stream", StringComparison.OrdinalIgnoreCase))
                                        || type == "application/pdf"
                                        || type == "application/vnd.openxmlformats-officedocument.wordprocessingml.document"
                                        || type == "application/msword"
                                        || type == "application/vnd.openxmlformats-officedocument.presentationml.presentation"
                                        || type == "application/vnd.ms-powerpoint"
                                        || type == "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
                                        || type == "application/vnd.ms-excel";
                                    ;
                                }
                                <i class="@iconClass fs-5"></i>
                                <span class="text-truncate" style="max-width:260px;" title="@item.Document.FileName">@item.Document.FileName</span>

                                @if (type == "application/pdf" && item.IsPdfSigned)
                                {
                                    <i class="bi bi-check-circle-fill text-success"
                                       title="@Localizer["PDF je digitálně podepsán"]"
                                       data-bs-toggle="tooltip"
                                       style="cursor:pointer;"
                                       onclick="showSignatureInfo(@item.Document.Id)"></i>
                                }

                                @if (isPreviewable)
                                {
                                    <button type="button"
                                            class="btn btn-sm btn-outline-secondary"
                                            onclick="showPreviewModal(@item.Document.Id, '@type', '@item.Document.FileName')">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                }
                            </div>
                        </td>
                        <td class="d-none d-md-table-cell text-muted small">@item.Document.UploadedAt.ToLocalTime().ToString("g")</td>
                        <td class="d-none d-sm-table-cell text-muted small">@(item.Document.FileSize / 1024) KB</td>
                        <td>
                            <div class="d-flex flex-wrap gap-1">
                                <a asp-action="Download" asp-route-id="@item.Document.Id" asp-route-culture="@culture"
                                   class="btn btn-sm btn-success">
                                    <i class="bi bi-download"></i>
                                </a>
                                <button type="button"
                                        class="btn btn-sm btn-info"
                                        onclick="showRenameModal(@item.Document.Id, '@Html.Raw(item.Document.FileName?.Replace("'", "\\'"))')">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button type="button"
                                        class="btn btn-sm btn-warning"
                                        onclick="showMoveModal(@item.Document.Id, '@Html.Raw(item.Document.FileName?.Replace("'", "\\'"))', @(currentFolderId?.ToString() ?? "null"))">
                                    <i class="bi bi-folder-symlink"></i>
                                </button>
                                <form asp-action="Delete" asp-route-id="@item.Document.Id" method="post" style="display:inline;" asp-route-culture="@culture">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="folderId" value="@currentFolderId" />
                                    <button type="submit" class="btn btn-sm btn-danger"
                                            onclick="return confirm('@Localizer["Smazat tento soubor?"]');">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
    else if (!Model.SubFolders.Any())
    {
        <div class="alert alert-info">@Localizer["Nic tu zatím není."]</div>
    }
    else
    {
        <p class="text-muted small">@Localizer["Žádné soubory v této složce."]</p>
    }
</div>

<!-- ===== MODALS ===== -->

<!-- New Folder Modal -->
<div class="modal fade" id="newFolderModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-folder-plus me-2"></i>@Localizer["Nová složka"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="CreateFolder" method="post" asp-route-culture="@culture">
                @Html.AntiForgeryToken()
                <input type="hidden" name="parentFolderId" value="@currentFolderId" />
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="newFolderName" class="form-label">@Localizer["Název složky"]</label>
                        <input type="text" class="form-control" id="newFolderName" name="name" required
                               placeholder="@Localizer["Zadejte název složky"]" autofocus />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["Zrušit"]</button>
                    <button type="submit" class="btn btn-primary">@Localizer["Vytvořit"]</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Rename Folder Modal -->
<div class="modal fade" id="renameFolderModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-pencil me-2"></i>@Localizer["Přejmenovat složku"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="RenameFolder" method="post" asp-route-culture="@culture">
                @Html.AntiForgeryToken()
                <input type="hidden" id="renameFolderId" name="id" />
                <input type="hidden" id="renameFolderParentId" name="parentFolderId" />
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="renameFolderName" class="form-label">@Localizer["Nový název"]</label>
                        <input type="text" class="form-control" id="renameFolderName" name="newName" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["Zrušit"]</button>
                    <button type="submit" class="btn btn-primary">@Localizer["Přejmenovat"]</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Rename File Modal -->
<div class="modal fade" id="renameModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@Localizer["Přejmenovat soubor"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Rename" method="post" asp-route-culture="@culture">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" id="renameDocumentId" name="id" />
                    <input type="hidden" name="folderId" value="@currentFolderId" />
                    <div class="mb-3">
                        <label for="newName" class="form-label">@Localizer["Nový název"]</label>
                        <input type="text" class="form-control" id="newName" name="newName" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["Zrušit"]</button>
                    <button type="submit" class="btn btn-primary">@Localizer["Přejmenovat"]</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Move to Folder Modal -->
<div class="modal fade" id="moveModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-folder-symlink me-2"></i>@Localizer["Přesunout soubor"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="MoveToFolder" method="post" asp-route-culture="@culture">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" id="moveDocumentId" name="documentId" />
                    <input type="hidden" name="currentFolderId" value="@currentFolderId" />
                    <p>@Localizer["Soubor"]: <strong id="moveFileName"></strong></p>
                    <div class="mb-3">
                        <label for="targetFolderSelect" class="form-label">@Localizer["Vyberte cílovou složku"]</label>
                        <select id="targetFolderSelect" name="targetFolderId" class="form-select">
                            <option value="">@Localizer["(Kořenová složka)"]</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["Zrušit"]</button>
                    <button type="submit" class="btn btn-primary">@Localizer["Přesunout"]</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Preview Modal -->
<div class="modal fade" id="previewModal" tabindex="-1" aria-labelledby="previewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="previewModalLabel">@Localizer["Náhled dokumentu"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="previewModalBody" style="min-height:60vh;">
                <div class="text-center">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">@Localizer["Načítání..."]</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Signature Modal -->
<div class="modal fade" id="signatureModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@Localizer["Informace o digitálním podpisu"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="signatureContent">
                <div class="text-center">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">@Localizer["Načítání..."]</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Drop feedback toast -->
<div class="position-fixed bottom-0 end-0 p-3" style="z-index:9999">
    <div id="dropToast" class="toast align-items-center text-bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body" id="dropToastBody"></div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // ---- Drag and Drop ----
    var draggedDocId = null;

    function onDragStart(event, docId) {
        draggedDocId = docId;
        event.dataTransfer.effectAllowed = 'move';
        event.currentTarget.classList.add('dragging');
        // Show parent drop zone if inside a subfolder
        var pz = document.getElementById('parentDropZone');
        if (pz) pz.classList.remove('d-none');
    }

    function onDragEnd(event) {
        event.currentTarget.classList.remove('dragging');
        document.querySelectorAll('.drag-over').forEach(el => el.classList.remove('drag-over'));
        var pz = document.getElementById('parentDropZone');
        if (pz) pz.classList.add('d-none');
    }

    function onDropToFolder(event, folderId, dropTarget) {
        event.preventDefault();
        dropTarget.classList.remove('drag-over');
        if (draggedDocId === null) return;

        var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        var body = new URLSearchParams();
        body.append('documentId', draggedDocId);
        if (folderId !== null && folderId !== 'null') body.append('targetFolderId', folderId);
        body.append('__RequestVerificationToken', token);

        fetch('@Url.Action("MoveFileApi", "Document")', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: body.toString()
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                showToast('@Localizer["Soubor byl přesunut."]', 'success');
                setTimeout(() => location.reload(), 800);
            } else {
                showToast(data.error || '@Localizer["Přesun se nezdařil."]', 'danger');
            }
        })
        .catch(() => showToast('@Localizer["Přesun se nezdařil."]', 'danger'));

        draggedDocId = null;
    }

    function showToast(message, type) {
        var toast = document.getElementById('dropToast');
        var body = document.getElementById('dropToastBody');
        toast.className = 'toast align-items-center text-bg-' + type + ' border-0';
        body.textContent = message;
        new bootstrap.Toast(toast, { delay: 2500 }).show();
    }

    // ---- Folder modals ----
    function showNewFolderModal() {
        document.getElementById('newFolderName').value = '';
        new bootstrap.Modal(document.getElementById('newFolderModal')).show();
        setTimeout(() => document.getElementById('newFolderName').focus(), 400);
    }

    function showRenameFolderModal(folderId, currentName, parentId) {
        document.getElementById('renameFolderId').value = folderId;
        document.getElementById('renameFolderName').value = currentName;
        document.getElementById('renameFolderParentId').value = parentId !== null ? parentId : '';
        new bootstrap.Modal(document.getElementById('renameFolderModal')).show();
    }

    // ---- File modals ----
    function showRenameModal(documentId, currentName) {
        document.getElementById('renameDocumentId').value = documentId;
        document.getElementById('newName').value = currentName;
        new bootstrap.Modal(document.getElementById('renameModal')).show();
    }

    function showMoveModal(documentId, fileName, currentFolderIdVal) {
        document.getElementById('moveDocumentId').value = documentId;
        document.getElementById('moveFileName').textContent = fileName;

        // Populate folder list
        var select = document.getElementById('targetFolderSelect');
        select.innerHTML = '<option value="">@Localizer["(Kořenová složka)"]</option>';

        @foreach (var folder in Model.AllFolders)
        {
            <text>
            var opt = document.createElement('option');
            opt.value = '@folder.Id';
            opt.textContent = '@Html.Raw(folder.Name.Replace("'", "\\'"))';
            if (@folder.Id === currentFolderIdVal) opt.selected = true;
            select.appendChild(opt);
            </text>
        }

        new bootstrap.Modal(document.getElementById('moveModal')).show();
    }

    // ---- Preview modal ----
    function showPreviewModal(documentId, type, fileName) {
        document.getElementById('previewModalLabel').textContent = '@Localizer["Náhled"]' + ': ' + fileName;
        document.getElementById('previewModalBody').innerHTML = '<div class="text-center"><div class="spinner-border" role="status"></div></div>';

        var previewUrl = '/Document/Preview?id=' + documentId;
        new bootstrap.Modal(document.getElementById('previewModal')).show();

        setTimeout(function () {
            var content = '';
            if (type === 'application/pdf' ||
                type === 'application/vnd.openxmlformats-officedocument.wordprocessingml.document' ||
                type === 'application/msword' ||
                type === 'application/vnd.openxmlformats-officedocument.presentationml.presentation' ||
                type === 'application/vnd.ms-powerpoint' ||
                type === 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' ||
                type === 'application/vnd.ms-excel') {
                content = '<iframe src="' + previewUrl + '" width="100%" height="600px"></iframe>';
            } else if (type.startsWith('image/')) {
                content = '<img src="' + previewUrl + '" alt="@Localizer["Náhled obrázku"]" class="img-fluid" />';
            } else if (type.startsWith('text/')) {
                fetch(previewUrl).then(r => r.text()).then(data => {
                    var pre = document.createElement('pre');
                    pre.style.whiteSpace = 'pre-wrap';
                    pre.style.wordBreak = 'break-all';
                    pre.textContent = data;
                    document.getElementById('previewModalBody').innerHTML = '';
                    document.getElementById('previewModalBody').appendChild(pre);
                }).catch(() => {
                    document.getElementById('previewModalBody').innerHTML = '<div class="alert alert-danger">@Localizer["Nepodařilo se načíst textový soubor."]</div>';
                });
                return;
            } else {
                content = '<div class="alert alert-info">@Localizer["Náhled tohoto typu souboru není podporován."]</div>';
            }
            document.getElementById('previewModalBody').innerHTML = content;
        }, 400);
    }

    // ---- Signature modal ----
    function showSignatureInfo(documentId) {
        new bootstrap.Modal(document.getElementById('signatureModal')).show();
        document.getElementById('signatureContent').innerHTML = '<div class="text-center"><div class="spinner-border" role="status"></div></div>';

        fetch('@Url.Action("GetPdfSignatureInfo")' + '?id=' + documentId)
            .then(r => r.json())
            .then(data => {
                var content = '<div class="alert alert-success"><i class="bi bi-check-circle me-2"></i>@Localizer["PDF je digitálně podepsán"]</div>';
                if (data.signerName) content += '<p><strong>@Localizer["Podepsáno"]:</strong> ' + data.signerName + '</p>';
                if (data.signatureDate) content += '<p><strong>@Localizer["Datum podpisu"]:</strong> ' + data.signatureDate + '</p>';
                content += '<p><strong>@Localizer["Počet podpisů"]:</strong> ' + data.signatureCount + '</p>';
                document.getElementById('signatureContent').innerHTML = content;
            })
            .catch(() => {
                document.getElementById('signatureContent').innerHTML = '<div class="alert alert-danger">@Localizer["Nepodařilo se načíst informace o podpisu."]</div>';
            });
    }
</script>
}
