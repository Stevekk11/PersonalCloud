@model PersonalCloud.Models.AdminLogsViewModel
@{
    ViewData["Title"] = "Admin - Logs";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">
            <h2 class="mb-4"><i class="bi bi-journal-text me-2"></i>Application Logs</h2>

            @if (!Model.IsAuthenticated)
            {
                <div class="card shadow-sm">
                    <div class="card-header bg-dark text-white">
                        <i class="bi bi-lock me-2"></i>Admin Authentication Required
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                        {
                            <div class="alert alert-danger" role="alert">
                                <i class="bi bi-exclamation-triangle me-2"></i>@Model.ErrorMessage
                            </div>
                        }
                        <form method="post" asp-action="Logs">
                            @Html.AntiForgeryToken()
                            <div class="mb-3">
                                <label for="Password" class="form-label fw-bold">Admin Password</label>
                                <input type="password" class="form-control" id="Password" name="Password"
                                       placeholder="Enter admin password" autocomplete="current-password" required />
                            </div>
                            <button type="submit" class="btn btn-dark w-100">
                                <i class="bi bi-unlock me-2"></i>View Logs
                            </button>
                        </form>
                    </div>
                </div>
            }
            else
            {
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="d-flex align-items-end gap-2 flex-wrap">
                        @if (Model.LogFiles.Count > 1)
                        {
                            <form method="get" asp-action="Logs" class="d-flex align-items-end gap-2 flex-wrap">
                                <div>
                                    <label for="selectedFile" class="form-label fw-bold mb-1">Log File</label>
                                    <select class="form-select" id="selectedFile" name="selectedFile" onchange="this.form.submit()">
                                        @foreach (var file in Model.LogFiles)
                                        {
                                            <option value="@file" selected="@(file == Model.SelectedFile)">@file</option>
                                        }
                                    </select>
                                </div>
                            </form>
                        }
                        else
                        {
                            <span class="text-muted">
                                <i class="bi bi-file-text me-1"></i>@(Model.SelectedFile ?? "No log files found")
                            </span>
                        }
                    </div>
                    <form method="post" asp-action="Logout">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-secondary btn-sm">
                            <i class="bi bi-box-arrow-right me-1"></i>Sign out
                        </button>
                    </form>
                </div>

                <div class="card shadow-sm">
                    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                        <span><i class="bi bi-terminal me-2"></i>@(Model.SelectedFile ?? "No file")</span>
                        <small class="text-light opacity-75">Last 500 lines</small>
                    </div>
                    <div class="card-body p-0">
                        <pre class="m-0 p-3" style="background:#1e1e1e; color:#d4d4d4; font-size:0.8rem; max-height:70vh; overflow-y:auto; white-space:pre-wrap; word-break:break-all;">@Model.LogContent</pre>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
