@using Microsoft.AspNetCore.Mvc.Localization
@model PersonalCloud.Models.AdminConsoleViewModel
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["Admin - Konzole"];
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2><i class="bi bi-terminal me-2"></i>@Localizer["Správcovská konzole"]</h2>
                <a asp-action="Logs" class="btn btn-outline-dark btn-sm">
                    <i class="bi bi-journal-text me-1"></i>@Localizer["Zpět na logy"]
                </a>
            </div>

            @if (!Model.IsAuthenticated)
            {
                <div class="card shadow-sm">
                    <div class="card-header bg-dark text-white">
                        <i class="bi bi-lock me-2"></i>@Localizer["Vyžadována autentizace administrátora"]
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                        {
                            <div class="alert alert-danger" role="alert">
                                <i class="bi bi-exclamation-triangle me-2"></i>@Model.ErrorMessage
                            </div>
                        }
                        <form method="post" asp-action="Console">
                            @Html.AntiForgeryToken()
                            <div class="mb-3">
                                <label for="Password" class="form-label fw-bold">@Localizer["Heslo administrátora"]</label>
                                <input type="password" class="form-control" id="Password" name="Password"
                                       placeholder="@Localizer["Zadejte heslo administrátora"]" autocomplete="current-password" required />
                            </div>
                            <button type="submit" class="btn btn-dark w-100">
                                <i class="bi bi-unlock me-2"></i>@Localizer["Otevřít konzoli"]
                            </button>
                        </form>
                    </div>
                </div>
            }
            else
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-body">
                        <form method="post" asp-action="Console">
                            @Html.AntiForgeryToken()
                            <div class="input-group">
                                <span class="input-group-text bg-dark text-white font-monospace">bash$</span>
                                <input type="text" name="Command" class="form-control font-monospace" 
                                       placeholder="@Localizer["Zadejte příkaz..."]" autofocus required />
                                <button type="submit" class="btn btn-dark">
                                    <i class="bi bi-play-fill me-1"></i>@Localizer["Spustit"]
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                @if (Model.Output != null)
                {
                    <div class="card shadow-sm">
                        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-text-left me-2"></i>@Localizer["Výstup příkazu"]</span>
                            <button class="btn btn-sm btn-outline-light" onclick="navigator.clipboard.writeText(document.getElementById('cmdOutput').innerText)">
                                <i class="bi bi-clipboard me-1"></i>@Localizer["Kopírovat"]
                            </button>
                        </div>
                        <div class="card-body p-0">
                            <pre id="cmdOutput" class="m-0 p-3" style="background:#1e1e1e; color:#d4d4d4; font-size:0.85rem; min-height:200px; max-height:60vh; overflow-y:auto; white-space:pre-wrap; word-break:break-all;">@Model.Output</pre>
                        </div>
                    </div>
                }
                
                <div class="mt-3 d-flex justify-content-end">
                    <form method="post" asp-action="Logout">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-secondary btn-sm">
                            <i class="bi bi-box-arrow-right me-1"></i>@Localizer["Odhlásit se"]
                        </button>
                    </form>
                </div>
            }
        </div>
    </div>
</div>
