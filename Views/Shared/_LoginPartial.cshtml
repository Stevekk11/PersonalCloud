@using Microsoft.AspNetCore.Identity
@using PersonalCloud.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Manage/Index" title="@Localizer["Manage"]">@Localizer["HelloUser", User.Identity?.Name]</a>
        </li>
        <li class="nav-item">
            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button type="submit" class="nav-link btn btn-link text-dark">@Localizer["Logout"]</button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item m-1">
            <a class="btn btn-outline-success w-100" asp-area="Identity" asp-page="/Account/Register">
                <i class="bi bi-person-plus me-1"></i>@Localizer["Register"]
            </a>
        </li>
        <li class="nav-item m-1">
            <a class="btn btn-primary w-100" asp-area="Identity" asp-page="/Account/Login">
                <i class="bi bi-box-arrow-in-right me-1"></i>@Localizer["Login"]
            </a>
        </li>
    }
</ul>