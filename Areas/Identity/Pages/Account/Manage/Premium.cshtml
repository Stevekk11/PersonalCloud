@page
@using Microsoft.AspNetCore.Mvc.Localization
@model PremiumModel
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["Prémiový účet"];
    ViewData["ActivePage"] = ManageNavPages.Premium;
}

<h3>@ViewData["Title"]</h3>
<partial name="_StatusMessage" for="StatusMessage" />

<div class="row">
    <div class="col-md-8">
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">@Localizer["Stav Premium"]</h5>
            </div>
            <div class="card-body">
                @if (Model.IsPremium)
                {
                    <div class="alert alert-success" role="alert">
                        <i class="bi bi-star-fill me-2"></i>
                        <strong>@Localizer["Jste Premium uživatel!"]</strong>
                    </div>
                    <p>@Localizer["Máte přístup ke všem prémiovým funkcím."]</p>
                    <form method="post" asp-page-handler="Downgrade">
                        <button type="submit" class="btn btn-warning">@Localizer["Zrušit Premium"]</button>
                    </form>
                }
                else
                {
                    <div class="alert alert-info" role="alert">
                        <i class="bi bi-info-circle me-2"></i>
                        @Localizer["Aktuálně máte standardní účet."]
                    </div>
                    <p>@Localizer["Upgradujte na Premium pro odemknutí dalších funkcí!"]</p>
                    
                    @if (Model.CanUpgradeToPremium)
                    {
                        <form method="post" asp-page-handler="Upgrade">
                            <button type="submit" class="btn btn-primary">@Localizer["Upgradovat na Premium"]</button>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-warning" role="alert">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            @Localizer["Prémiové účty jsou momentálně nedostupné kvůli omezené kapacitě úložiště."]
                        </div>
                    }
                }
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">@Localizer["Kapacita systému"]</h5>
            </div>
            <div class="card-body">
                <table class="table">
                    <tbody>
                        <tr>
                            <td>@Localizer["Dostupné místo na disku"]</td>
                            <td><strong>@Model.AvailableDiskSpaceGB.ToString("F2") GB</strong></td>
                        </tr>
                        <tr>
                            <td>@Localizer["Maximální počet Premium uživatelů"]</td>
                            <td><strong>@Model.MaxPremiumUsers</strong></td>
                        </tr>
                        <tr>
                            <td>@Localizer["Aktuální počet Premium uživatelů"]</td>
                            <td><strong>@Model.CurrentPremiumUsers</strong></td>
                        </tr>
                        <tr>
                            <td>@Localizer["Volné sloty pro Premium"]</td>
                            <td><strong>@Model.AvailablePremiumSlots</strong></td>
                        </tr>
                    </tbody>
                </table>
                <p class="text-muted small">
                    <i class="bi bi-info-circle me-1"></i>
                    @Localizer["Každý prémiový účet vyžaduje 50 GB volného místa na disku."]
                </p>
            </div>
        </div>
    </div>
</div>
